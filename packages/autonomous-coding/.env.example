# MiniMax API（推荐）
ANTHROPIC_AUTH_TOKEN=your-minimax-api-key
ANTHROPIC_BASE_URL=https://api.minimaxi.com/anthropic
ANTHROPIC_MODEL=MiniMax-M2.7

# 或者使用 Anthropic 官方 API
# ANTHROPIC_API_KEY=your-anthropic-api-key

# 提示词配置（可选，使用默认内置路径）
# AUTONOMOUS_CODING_PROMPTS_DIR=./src/prompts
# AUTONOMOUS_CODING_INITIALIZER_PROMPT=./src/prompts/initializer_prompt.md
# AUTONOMOUS_CODING_CODING_PROMPT=./src/prompts/coding_prompt.md
# AUTONOMOUS_CODING_APP_SPEC=./src/prompts/app_spec.txt
